{
  "name": "ublitz.js",
  "version": "1.3.0",
  "description": "This package is written with typescript and built on top of uWebSockets.js#20.52.0. It adds several utilities to simplify the development (routing, ajv validation, extensible request abort handler, documentation for many http-headers). Also it has a little more documentation of original websockets and DeclarativeResponse class",
  "keywords": [
    "uWebSockets.js",
    "fast",
    "light",
    "utilities",
    "http",
    "ws",
    "low-level",
    "library",
    "minimal",
    "DX"
  ],
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git:https://github.com/Guthib-of-Dan/uBlitz.js.git"
  },
  "homepage": "https://github.com/Guthib-of-Dan/uBlitz.js#readme",
  "author": "Daniel",
  "type": "module",
  "main": "./index.mts",
  "dependencies": {
    "@sinclair/typebox": "^0.34.33",
    "ajv": "^8.17.1",
    "busboy": "^1.6.0",
    "nanoid": "^5.1.5",
    "tseep": "^1.3.1",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.52.0"
  },
  "exports": {
    ".": "./index.mts",
    "./body": "./body.mts",
    "./codes": "./http-codes.mts",
    "./static": "./sendFile.mts",
    "./logger": "./logger.mts",
    "./router": "./router.mts",
    "./proto": "./proto.mts",
    "./all": "./all.mts"
  },
  "devDependencies": {
    "fast-jwt": "^6.0.1",
    "openapi3-ts": "^4.4.0",
    "protobufjs": "^7.4.0",
    "protobufjs-cli": "^1.1.3",
    "cookie": "^1.0.2",
    "vitest": "^3.1.1",
    "puppeteer-core": "^24.6.0"
  }
}
